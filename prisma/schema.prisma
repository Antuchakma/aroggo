generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  fullName   String
  email      String    @unique
  password   String
  role       Role
  createdAt  DateTime  @default(now())

  doctor     Doctor?
  patient    Patient?
}

model Doctor {
  id             Int       @id @default(autoincrement())
  user           User      @relation(fields: [userId], references: [id])
  userId         Int       @unique
  specialization String
  licenseNumber  String
  hospitalName   String

  prescriptions  Prescription[]
  medicalReports MedicalReport[]
}

model Patient {
  id             Int       @id @default(autoincrement())
  user           User      @relation(fields: [userId], references: [id])
  userId         Int       @unique
  dateOfBirth    DateTime
  gender         String
  bloodGroup     String

  prescriptions  Prescription[]
  medicalHistory PatientMedicalHistory[]
  medicalReports MedicalReport[]
  chatMessages   ChatMessage[]
}

model Medicine {
  id            Int       @id @default(autoincrement())
  name          String
  manufacturer  String
  description   String

  prescriptions PrescriptionMedicine[]
}

model Prescription {
  id        Int       @id @default(autoincrement())
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
  doctorId  Int
  patient   Patient   @relation(fields: [patientId], references: [id])
  patientId Int
  diagnosis String
  notes     String
  createdAt DateTime  @default(now())

  medicines PrescriptionMedicine[]
}

model PrescriptionMedicine {
  id             Int          @id @default(autoincrement())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  prescriptionId Int
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  medicineId     Int

  dosage    String
  frequency String
  duration  String
  purpose   String
}

model MedicalReport {
  id            Int       @id @default(autoincrement())
  patient       Patient   @relation(fields: [patientId], references: [id])
  patientId     Int
  doctor        Doctor?   @relation(fields: [doctorId], references: [id])
  doctorId      Int?
  reportType    String
  fileUrl       String
  extractedText String?
  createdAt     DateTime  @default(now())
}

model PatientMedicalHistory {
  id            Int      @id @default(autoincrement())
  patient       Patient  @relation(fields: [patientId], references: [id])
  patientId     Int
  conditionName String
  details       String
  startDate     DateTime
  endDate       DateTime?
  isChronic     Boolean
}

model ChatMessage {
  id           Int       @id @default(autoincrement())
  patient      Patient   @relation(fields: [patientId], references: [id])
  patientId    Int
  messageText  String
  responseText String
  messageType  String
  createdAt    DateTime  @default(now())
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
}